{
  "name": "openmux",
  "version": "0.3.137",
  "description": "Terminal multiplexer with master-stack tiling layout",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "openmux": "./bin/openmux"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run build && ./dist/openmux",
    "dev": "bun run --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "build": "./scripts/build.sh",
    "build:release": "./scripts/build.sh --release",
    "install:local": "./scripts/build.sh --install",
    "update:submodules": "./scripts/update-submodules.sh",
    "test": "bun test ./src ./tests && (cd native/zig-pty && bash ../../scripts/zig.sh build test --summary all) && (cd native/zig-git && bash ../../scripts/zig.sh build test --summary all) && bun run test:zig-ghostty-wrapper && bash scripts/cleanup-vendor-tmp.sh",
    "test:ts": "bun test ./src ./tests",
    "test:pty": "cd native/zig-pty && bash ../../scripts/zig.sh build test --summary all",
    "test:git": "cd native/zig-git && bash ../../scripts/zig.sh build test --summary all && bash ../../scripts/cleanup-vendor-tmp.sh",
    "test:zig-ghostty-wrapper": "./scripts/test-ghostty-vt.sh",
    "test:ghostty-wrapper": "bun run test:zig-ghostty-wrapper",
    "test:ghostty-vt": "bun run test:zig-ghostty-wrapper",
    "test:watch": "bun test --watch",
    "check:circular": "bunx madge --circular --extensions ts,tsx src/",
    "lint": "eslint src",
    "lint:dead": "knip --no-gitignore",
    "config:doc": "bun scripts/generate-config-doc.ts",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release",
    "publish:npm": "./scripts/publish.sh",
    "lfg": "bun release && git push --follow-tags && bun publish:npm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged",
    "pre-push": "bun run typecheck && bun run test:ts",
    "commit-msg": "bunx commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/openmux.git"
  },
  "author": "monotykamary",
  "license": "MIT",
  "homepage": "https://github.com/monotykamary/openmux#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/openmux/issues"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "tui",
    "tmux",
    "zellij",
    "bun",
    "opentui"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "standard-version": "^9.5.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "brace-expansion": "^5.0.6",
    "minimatch": ">=10.2.5",
    "flatted": "^3.4.2",
    "fast-uri": "^3.1.2",
    "handlebars": "^4.7.9"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@opentui/core": "^0.2.16",
    "@opentui/solid": "^0.2.16",
    "errore": "^0.14.1",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  }
}
