{
  "name": "openmux",
  "version": "0.3.37",
  "description": "Terminal multiplexer with master-stack tiling layout",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "openmux": "./bin/openmux"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run build && ./dist/openmux",
    "dev": "bun run --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "build": "./scripts/build.sh",
    "build:release": "./scripts/build.sh --release",
    "install:local": "./scripts/build.sh --install",
    "update:submodules": "./scripts/update-submodules.sh",
    "test": "bun test && (cd native/zig-pty && bash ../../scripts/zig.sh build test --summary all) && (cd native/zig-git && bash ../../scripts/zig.sh build test --summary all) && bun run test:zig-ghostty-wrapper",
    "test:ts": "bun test",
    "test:pty": "cd native/zig-pty && bash ../../scripts/zig.sh build test --summary all",
    "test:git": "cd native/zig-git && bash ../../scripts/zig.sh build test --summary all",
    "test:zig-ghostty-wrapper": "./scripts/test-ghostty-vt.sh",
    "test:ghostty-wrapper": "bun run test:zig-ghostty-wrapper",
    "test:ghostty-vt": "bun run test:zig-ghostty-wrapper",
    "test:watch": "bun test --watch",
    "check:circular": "bunx madge --circular --extensions ts,tsx src/",
    "lint": "eslint src",
    "config:doc": "bun scripts/generate-config-doc.ts",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:first": "standard-version --first-release",
    "publish:npm": "./scripts/publish.sh",
    "lfg": "bun release && git push --follow-tags && bun publish:npm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/openmux.git"
  },
  "author": "monotykamary",
  "license": "MIT",
  "homepage": "https://github.com/monotykamary/openmux#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/openmux/issues"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "tui",
    "tmux",
    "zellij",
    "bun",
    "opentui"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "standard-version": "^9.5.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@opentui/core": "^0.1.90",
    "@opentui/solid": "^0.1.90",
    "errore": "^0.14.1",
    "solid-js": "^1.9.12",
    "zod": "^4.3.6"
  }
}
